# ==========================================
# Git 换行符配置
# 确保跨平台开发时文件换行符的一致性
# ==========================================

# 默认行为：自动检测文本文件并进行换行符规范化
* text=auto

# ==========================================
# Shell 脚本 - 必须使用 LF (Linux 换行符)
# 这些脚本在 Docker 容器 (Linux) 中执行
# ==========================================
*.sh text eol=lf

# ==========================================
# Python 文件 - 使用 LF
# DAG 文件和脚本在 Airflow 容器中运行
# ==========================================
*.py text eol=lf

# ==========================================
# 配置文件 - 使用 LF
# 这些文件会被挂载到 Docker 容器中
# ==========================================
*.yml text eol=lf
*.yaml text eol=lf
*.conf text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.env text eol=lf
.env* text eol=lf
Dockerfile text eol=lf
docker-compose* text eol=lf

# ==========================================
# 文档文件 - 使用 LF (保持一致性)
# ==========================================
*.md text eol=lf
*.txt text eol=lf

# ==========================================
# SQL 文件 - 使用 LF
# ==========================================
*.sql text eol=lf

# ==========================================
# JSON 文件 - 使用 LF
# ==========================================
*.json text eol=lf

# ==========================================
# 二进制文件 - 不进行换行符转换
# ==========================================
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.gz binary
*.zip binary
*.tar binary
*.7z binary